{
	"name": "marking-grid",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"imports": { "#*": "./src/*" },
	"scripts": {
		"db:down": "dotenvx run --convention=flow -- docker compose down",
		"db:logs": "dotenvx run --convention=flow -- docker compose logs -f postgres",
		"db:up": "dotenvx run --convention=flow -- docker compose up -d postgres",
		"dev": "dotenvx run --convention=flow -- next dev",
		"build": "dotenvx run --convention=flow -- next build",
		"start": "dotenvx run --convention=flow -- next start",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build",
		"storybook:browser:install": "playwright install chromium",
		"storybook:browser:install:ci": "playwright install --with-deps chromium --only-shell",
		"test": "vitest run --project=unit --project=integration --project=storybook",
		"test:unit": "vitest run --project=unit",
		"test:integration": "vitest run --project=integration",
		"test:storybook": "vitest run --project=storybook",
		"test:watch": "vitest --project=unit --project=integration --project=storybook",
		"test:e2e": "dotenvx run --convention=flow -- playwright test",
		"check": "biome check --error-on-warnings --max-diagnostics=none",
		"check-types": "tsc --noEmit",
		"db:migrate:down": "dotenvx run --convention=flow -- node src/db/migrate.ts down",
		"db:migrate:status": "dotenvx run --convention=flow -- node src/db/migrate.ts status",
		"db:migrate:up": "dotenvx run --convention=flow -- node src/db/migrate.ts up",
		"db:reset": "dotenvx run --convention=flow -- node src/db/migrate.ts reset",
		"db:types:generate": "dotenvx run --convention=flow -- kysely-codegen --numeric-parser number --camel-case --out-file src/db/generated/db.ts"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@emotion/react": "^11.11.4",
		"@emotion/styled": "^11.11.0",
		"@fontsource/monaspace-neon": "^5.2.5",
		"@fontsource/roboto": "^5.0.0",
		"@mui/icons-material": "^9.0.1",
		"@mui/material": "^9.0.1",
		"@mui/material-nextjs": "^9.0.1",
		"@shikijs/langs": "^4.1.0",
		"@shikijs/themes": "^4.1.0",
		"change-case": "^5.4.4",
		"client-only": "^0.0.1",
		"csv-parse": "^6.2.1",
		"csv-stringify": "^6.7.0",
		"fuse.js": "^7.3.0",
		"immer": "^11.1.8",
		"js-yaml": "^4.1.0",
		"kysely": "^0.29.2",
		"nanoid": "^5.1.11",
		"next": "^16.2.6",
		"pg": "^8.21.0",
		"pg-cursor": "^2.20.0",
		"pino": "^10.3.1",
		"react": "^19.0.0",
		"react-dom": "^19.0.0",
		"server-only": "^0.0.1",
		"shiki": "^4.1.0",
		"typescript": "^6.0.3",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@dotenvx/dotenvx": "^1.69.1",
		"@playwright/test": "1.60.0",
		"@storybook/addon-vitest": "^10.4.1",
		"@storybook/nextjs-vite": "^10.4.1",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^25.9.1",
		"@types/pg": "^8.20.0",
		"@types/pg-cursor": "^2.7.2",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.0.0",
		"@vitest/browser-playwright": "^4.1.7",
		"kysely-codegen": "^0.20.0",
		"playwright": "^1.60.0",
		"storybook": "^10.4.1",
		"vite": "^8.0.14",
		"vitest": "^4.1.7"
	},
	"packageManager": "pnpm@11.1.1",
	"engines": { "node": ">=26" }
}
