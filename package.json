{
  "name": "marking-grid",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "db:down": "dotenvx run -- docker compose down",
    "db:logs": "dotenvx run -- docker compose logs -f postgres",
    "db:up": "dotenvx run -- docker compose up -d postgres",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "check": "biome check",
    "check-types": "tsc --noEmit",
    "prisma:generate": "dotenvx run -- prisma generate",
    "prisma:migrate:deploy": "dotenvx run -- prisma migrate deploy",
    "prisma:migrate:dev": "dotenvx run -- prisma migrate dev",
    "prisma:studio": "dotenvx run -- prisma studio",
    "prisma:validate": "dotenvx run -- prisma validate"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.0",
    "@fontsource/monaspace-neon": "^5.2.5",
    "@fontsource/roboto": "^5.0.0",
    "@mui/icons-material": "^9.0.1",
    "@mui/material": "^9.0.1",
    "@mui/material-nextjs": "^9.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "clsx": "^2.1.0",
    "csv-parse": "^6.2.1",
    "immer": "^11.1.8",
    "js-yaml": "^4.1.0",
    "next": "^16.2.6",
    "pg": "^8.20.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "shiki": "^4.0.2",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@dotenvx/dotenvx": "^1.65.0",
    "@storybook/nextjs": "^10.3.6",
    "@types/node": "^24.12.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "prisma": "^7.8.0",
    "storybook": "^10.3.6"
  },
  "packageManager": "pnpm@11.1.1"
}
