{
	"name": "marking-grid",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"imports": { "#*": "./src/*" },
	"scripts": {
		"db:down": "dotenvx run --convention=flow -- docker compose down",
		"db:logs": "dotenvx run --convention=flow -- docker compose logs -f postgres",
		"db:up": "dotenvx run --convention=flow -- docker compose up -d postgres",
		"dev": "dotenvx run --convention=flow -- next dev",
		"build": "dotenvx run --convention=flow -- next build",
		"start": "dotenvx run --convention=flow -- next start",
		"storybook": "storybook dev -p 6006",
		"storybook:build": "storybook build",
		"storybook:browser:install": "playwright install chromium",
		"test": "vitest run --project=unit --project=integration --project=storybook",
		"test:unit": "vitest run --project=unit",
		"test:integration": "vitest run --project=integration",
		"test:storybook": "vitest run --project=storybook",
		"test:watch": "vitest --project=unit --project=integration --project=storybook",
		"test:e2e": "dotenvx run --convention=flow -- node e2e/runE2e.ts",
		"check": "biome check --error-on-warnings --max-diagnostics=none",
		"check-types": "tsc --noEmit",
		"db:migrate:down": "dotenvx run --convention=flow -- node src/db/migrate.ts down",
		"db:migrate:status": "dotenvx run --convention=flow -- node src/db/migrate.ts status",
		"db:migrate:up": "dotenvx run --convention=flow -- node src/db/migrate.ts up",
		"db:reset": "dotenvx run --convention=flow -- node src/db/migrate.ts reset",
		"db:types:generate": "dotenvx run --convention=flow -- kysely-codegen --numeric-parser number --camel-case --out-file src/db/generated/db.ts"
	},
	"dependencies": {
		"@dnd-kit/core": "^6.3.1",
		"@dnd-kit/sortable": "^10.0.0",
		"@dnd-kit/utilities": "^3.2.2",
		"@emotion/react": "^11.14.0",
		"@emotion/styled": "^11.14.1",
		"@fontsource/monaspace-neon": "^5.2.5",
		"@fontsource/roboto": "^5.2.10",
		"@mui/icons-material": "^9.1.1",
		"@mui/material": "^9.1.1",
		"@mui/material-nextjs": "^9.1.1",
		"@shikijs/langs": "^4.2.0",
		"@shikijs/themes": "^4.2.0",
		"change-case": "^5.4.4",
		"client-only": "^0.0.1",
		"csv-parse": "^7.0.0",
		"csv-stringify": "^6.8.0",
		"fuse.js": "^7.4.2",
		"immer": "^11.1.8",
		"js-yaml": "^4.2.0",
		"kysely": "^0.29.2",
		"nanoid": "^5.1.14",
		"next": "^16.2.9",
		"pg": "^8.22.0",
		"pg-cursor": "^2.21.0",
		"pino": "^10.3.1",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"server-only": "^0.0.1",
		"shiki": "^4.2.0",
		"typescript": "^6.0.3",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@dotenvx/dotenvx": "^1.75.0",
		"@playwright/test": "1.61.0",
		"@storybook/addon-vitest": "^10.4.6",
		"@storybook/nextjs-vite": "^10.4.6",
		"@testcontainers/postgresql": "^12.0.3",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^26.0.0",
		"@types/pg": "^8.20.0",
		"@types/pg-cursor": "^2.7.2",
		"@types/react": "^19.2.17",
		"@types/react-dom": "^19.2.3",
		"@vitest/browser-playwright": "^4.1.9",
		"biome-plugin-no-type-assertion": "^1.1.1",
		"kysely-codegen": "^0.20.0",
		"playwright": "^1.61.0",
		"storybook": "^10.4.6",
		"vite": "^8.0.16",
		"vitest": "^4.1.9"
	},
	"packageManager": "pnpm@11.9.0",
	"engines": { "node": ">=26" }
}
