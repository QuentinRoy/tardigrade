generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RubricType {
  BOOLEAN
  ORDINAL
  NUMERICAL
}

enum SubmissionType {
  INDIVIDUAL
  TEAM
}

/// IMPORTANT MAINTAINER NOTE
///
/// Type compatibility between `Rubric.type` and typed rubric tables
/// (`BooleanRubric`, `OrdinalRubric`, `NumericalRubric`) is enforced at the
/// database layer with PostgreSQL triggers, not with Prisma relations alone.
///
/// See migration:
/// prisma/migrations/20260511113000_enforce_rubric_type_typed_tables/migration.sql
///
/// If you add a new value to RubricType (for example `TEXT`), you MUST:
/// 1. Add the new typed model (for example `TextRubric`) with `rubricId @unique`.
/// 2. Add trigger function + trigger in a new migration so inserts/updates into
///    that typed table require matching `Rubric.type`.
/// 3. Keep the `Rubric.type` immutability trigger updated so `Rubric.type`
///    cannot be changed after creation.
/// 4. Update import logic in src/import/importDataAction.ts accordingly.

model Submission {
  id          String         @id @default(cuid())
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  type        SubmissionType @default(INDIVIDUAL)
  assessments Assessment[]
  teamId      String?
  team        Team?          @relation(fields: [teamId], references: [id], onDelete: SetNull)
  studentId   String?
  student     Student?       @relation(fields: [studentId], references: [id], onDelete: SetNull)

  @@unique([teamId])
  @@unique([studentId])
}

model Team {
  id          String       @id @default(cuid())
  name        String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  students    Student[]
  submissions Submission[]

  @@unique([name])
}

model Student {
  id          String       @id
  familyName  String
  firstName   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  submissions Submission[]
  teams       Team[]
}

model Question {
  id          String       @id
  label       String?
  position    Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  rubrics     Rubric[]
  assessments Assessment[]
}

model Rubric {
  id              String             @id
  questionId      String
  position        Int
  description     String?
  label           String?
  type            RubricType
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  question        Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  booleanRubric   BooleanRubric?
  ordinalRubric   OrdinalRubric?
  numericalRubric NumericalRubric?
  assessments     RubricAssessment[]

  @@unique([questionId, position])
}

model BooleanRubric {
  id       String  @id @default(cuid())
  rubricId String  @unique
  marks    Decimal @db.Decimal(10, 2)
  rubric   Rubric  @relation(fields: [rubricId], references: [id], onDelete: Cascade)
}

model OrdinalRubric {
  id       String               @id @default(cuid())
  rubricId String               @unique
  rubric   Rubric               @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  marks    OrdinalRubricValue[]
}

model OrdinalRubricValue {
  id              String        @id @default(cuid())
  ordinalRubricId String
  label           String
  marks           Decimal       @db.Decimal(10, 2)
  ordinalRubric   OrdinalRubric @relation(fields: [ordinalRubricId], references: [id], onDelete: Cascade)

  @@unique([ordinalRubricId, label])
  @@index([ordinalRubricId])
}

model NumericalRubric {
  id       String  @id @default(cuid())
  rubricId String  @unique
  minScore Decimal @db.Decimal(10, 2)
  maxScore Decimal @db.Decimal(10, 2)
  minMarks Decimal @db.Decimal(10, 2)
  maxMarks Decimal @db.Decimal(10, 2)
  rubric   Rubric  @relation(fields: [rubricId], references: [id], onDelete: Cascade)
}

model Assessment {
  id           String             @id @default(cuid())
  submissionId String
  questionId   String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  submission   Submission         @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  question     Question           @relation(fields: [questionId], references: [id], onDelete: Cascade)
  assessments  RubricAssessment[]

  @@unique([submissionId, questionId])
}

model RubricAssessment {
  id                  String                     @id @default(cuid())
  assessmentId        String
  rubricId            String
  type                RubricType
  createdAt           DateTime                   @default(now())
  updatedAt           DateTime                   @updatedAt
  assessment          Assessment                 @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  rubric              Rubric                     @relation(fields: [rubricId], references: [id], onDelete: Cascade)
  booleanAssessment   BooleanRubricAssessment?
  ordinalAssessment   OrdinalRubricAssessment?
  numericalAssessment NumericalRubricAssessment?

  @@unique([assessmentId, rubricId])
}

model BooleanRubricAssessment {
  id                 String           @id @default(cuid())
  rubricAssessmentId String           @unique
  passed             Boolean
  rubricAssessment   RubricAssessment @relation(fields: [rubricAssessmentId], references: [id], onDelete: Cascade)
}

model OrdinalRubricAssessment {
  id                 String           @id @default(cuid())
  rubricAssessmentId String           @unique
  selectedLabel      String
  rubricAssessment   RubricAssessment @relation(fields: [rubricAssessmentId], references: [id], onDelete: Cascade)
}

model NumericalRubricAssessment {
  id                 String           @id @default(cuid())
  rubricAssessmentId String           @unique
  score              Decimal          @db.Decimal(10, 6)
  rubricAssessment   RubricAssessment @relation(fields: [rubricAssessmentId], references: [id], onDelete: Cascade)
}
