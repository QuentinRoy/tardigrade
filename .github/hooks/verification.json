{
	"version": 1,
	"hooks": {
		"SessionStart": [
			{
				"type": "command",
				"bash": "bash .github/hooks/project-tools.sh setup || true",
				"timeoutSec": 300
			}
		],
		"PostToolUse": [
			{
				"type": "command",
				"matcher": "edit|create|str_replace_editor|apply_patch",
				"bash": "bash .github/hooks/format-after-edit.sh",
				"timeoutSec": 30
			}
		],
		"Stop": [
			{
				"type": "command",
				"bash": "bash .github/hooks/check-types-before-stop.sh",
				"timeoutSec": 60
			}
		]
	}
}
