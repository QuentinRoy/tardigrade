{
	"$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
	"plugins": [
		"node_modules/biome-plugin-no-type-assertion/no-type-assertion.grit"
	],
	"vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
	"files": { "ignoreUnknown": false, "includes": ["**", "!.claude"] },
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 2,
		"lineEnding": "lf",
		"lineWidth": 80,
		"attributePosition": "auto",
		"bracketSameLine": false,
		"bracketSpacing": true,
		"expand": "never",
		"useEditorconfig": true
	},
	"linter": {
		"enabled": true,
		"domains": {
			"project": "recommended",
			"react": "recommended",
			"next": "recommended",
			"test": "recommended",
			"types": "recommended",
			"playwright": "all"
		},
		"rules": {
			"preset": "recommended",
			"complexity": {
				"noUselessTypeConstraint": "error",
				"useLiteralKeys": "off"
			},
			"correctness": {
				"noUnusedVariables": "error",
				"useExhaustiveDependencies": "error",
				"useHookAtTopLevel": "error",
				"useImportExtensions": "error",
				"useJsxKeyInIterable": {
					"level": "error",
					"options": { "checkShorthandFragments": true }
				},
				"noNestedComponentDefinitions": "error",
				"noUndeclaredDependencies": "error",
				"useJsonImportAttributes": "error"
			},
			"security": { "noSecrets": "off" },
			"style": {
				"noCommonJs": "error",
				"noNamespace": "error",
				"noNonNullAssertion": "error",
				"noRestrictedImports": {
					"level": "error",
					"options": {
						"patterns": [
							{
								"group": ["@/**"],
								"message": "The @/ path alias was removed (see docs/adr/0003). Use a #feature/… subpath for cross-feature imports or a relative ./… import within a feature."
							},
							{
								"group": [
									"#*",
									"#*/**",
									"!#*.ts",
									"!#*.tsx",
									"!#*.css",
									"!#*/**/*.ts",
									"!#*/**/*.tsx",
									"!#*/**/*.css"
								],
								"message": "Internal # subpath imports must include an explicit .ts/.tsx extension (see docs/adr/0003) so raw `node` execution resolves them."
							}
						]
					}
				},
				"useArrayLiterals": "error",
				"useAsConstAssertion": "error",
				"useImportType": "error"
			},
			"suspicious": {
				"noArrayIndexKey": "error",
				"noConsole": "error",
				"noExplicitAny": "error",
				"noExtraNonNullAssertion": "error",
				"noNonNullAssertedOptionalChain": "error",
				"noUnnecessaryConditions": "off",
				"noShadow": "error",
				"useArraySortCompare": "error"
			},
			"nursery": {
				"noMisusedPromises": "error",
				"noFloatingPromises": "error",
				"useReduceTypeParameter": "error",
				"useAwaitThenable": "error",
				"noUnsafePlusOperands": "error",
				"noUselessTypeConversion": "error"
			}
		},
		"includes": ["**", "!data/**/*.js", "!.next/**/*"]
	},
	"javascript": {
		"formatter": {
			"jsxQuoteStyle": "double",
			"quoteProperties": "asNeeded",
			"trailingCommas": "all",
			"semicolons": "always",
			"arrowParentheses": "always",
			"bracketSameLine": false,
			"quoteStyle": "double",
			"attributePosition": "auto",
			"bracketSpacing": true
		}
	},
	"html": { "formatter": { "selfCloseVoidElements": "never" } },
	"overrides": [
		{
			"includes": ["**/*.ts", "**/*.tsx", "**/*.mts", "**/*.cts"],
			"linter": {
				"rules": {
					"complexity": { "noArguments": "error" },
					"correctness": {
						"noConstAssign": "off",
						"noGlobalObjectCalls": "off",
						"noInvalidBuiltinInstantiation": "off",
						"noInvalidConstructorSuper": "off",
						"noSetterReturn": "off",
						"noUndeclaredVariables": "off",
						"noUnreachable": "off",
						"noUnreachableSuper": "off"
					},
					"style": { "useConst": "error" },
					"suspicious": {
						"noClassAssign": "off",
						"noDuplicateClassMembers": "off",
						"noDuplicateObjectKeys": "off",
						"noDuplicateParameters": "off",
						"noFunctionAssign": "off",
						"noImportAssign": "off",
						"noRedeclare": "off",
						"noUnsafeNegation": "off",
						"noVar": "error",
						"noWith": "off",
						"useGetterReturn": "off"
					}
				}
			}
		},
		{
			"includes": ["**/*.test.ts", "**/*.test.tsx"],
			"linter": {
				"rules": {
					"style": { "noNonNullAssertion": "off" },
					"suspicious": { "noShadow": "off" }
				}
			}
		}
	],
	"assist": {
		"enabled": true,
		"actions": { "source": { "organizeImports": "on" } }
	}
}
